{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "anytls",
      "tag": "anytls-in",
      "listen": "::",
      "listen_port": 8443,
      "users": [
        {
          "name": "user1",
          "password": "YOUR_ANYTLS_PASSWORD"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "cert.pem",
        "key_path": "key.pem"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "final": "direct"
  }
}
