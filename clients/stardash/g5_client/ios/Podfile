# G5 Client iOS — CocoaPods + Libbox symlink for singbox_mm
source 'https://github.com/CocoaPods/Specs.git'

platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

require 'fileutils'
app_fw = File.expand_path('Frameworks/Libbox.xcframework', __dir__)
plugin_fw_dir = File.expand_path('.symlinks/plugins/singbox_mm/ios/Frameworks', __dir__)
plugin_fw = File.join(plugin_fw_dir, 'Libbox.xcframework')

if File.exist?(app_fw)
  FileUtils.mkdir_p(plugin_fw_dir)
  FileUtils.rm_f(plugin_fw) if File.symlink?(plugin_fw) || File.exist?(plugin_fw)
  FileUtils.ln_sf(app_fw, plugin_fw)
  puts "Symlinked Libbox.xcframework for singbox_mm plugin"
end

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('Flutter', 'Generated.xcconfig'), __dir__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
